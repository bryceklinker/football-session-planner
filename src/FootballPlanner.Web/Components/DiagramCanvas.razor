@using FootballPlanner.Web.Models
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ILogger<DiagramCanvas> Logger

<svg id="@_svgId"
     data-testid="diagram-canvas"
     viewBox="0 0 100 @_pitchHeight.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
     style="width:100%;display:block;background:#2d5a27;cursor:@_cursor;overflow:visible;user-select:none;"
     @onclick="HandleSvgClick"
     @onmousemove="HandleSvgMouseMove">

    <defs>
        @for (var ai = 0; ai < State.Diagram.Arrows.Count; ai++)
        {
            var a = State.Diagram.Arrows[ai];
            var mFill = a.Color ?? ResolvedArrowColor(a.Style);
            <marker id="arr-@(_svgId)-@ai"
                    markerWidth="4" markerHeight="3"
                    refX="0" refY="1.5"
                    orient="auto">
                <polygon points="0 0,4 1.5,0 3" fill="@mFill"/>
            </marker>
        }
    </defs>

    <!-- Pitch markings -->
    @((MarkupString)BuildPitchMarkings())

    <!-- Goals -->
    @for (var gi = 0; gi < State.Diagram.Goals.Count; gi++)
    {
        var goal = State.Diagram.Goals[gi];
        var gref = $"goals/{gi}";
        @if (State.SelectedElement == gref)
        {
            <rect x="@(goal.X - 0.5)" y="@(goal.Y * _pitchHeight / 100 - 0.5)"
                  width="@(goal.Width + 1)" height="@(goal.Width / 7.0 + 1)"
                  fill="none" stroke="white" stroke-width="0.4" stroke-dasharray="1,1"
                  pointer-events="none"/>
        }
        <rect data-element="@gref"
              x="@goal.X" y="@(goal.Y * _pitchHeight / 100)"
              width="@goal.Width" height="@(goal.Width / 7.0)"
              fill="none" stroke="white" stroke-width="0.8"
              style="cursor:pointer;"
              @onmousedown="(e) => HandleElementMouseDown(e, gref)"
              @onmousedown:stopPropagation="true"
              @onclick:stopPropagation="true"
              @onclick="() => HandleElementClick(gref)"/>
    }

    <!-- Cones -->
    @for (var ci = 0; ci < State.Diagram.Cones.Count; ci++)
    {
        var cone = State.Diagram.Cones[ci];
        var cref = $"cones/{ci}";
        var cy = cone.Y * _pitchHeight / 100;
        var cs = cone.Size;
        @if (State.SelectedElement == cref)
        {
            <circle cx="@cone.X" cy="@cy" r="@(cs * 2.5)"
                    fill="none" stroke="white" stroke-width="0.4" stroke-dasharray="1,1"
                    pointer-events="none"/>
        }
        <polygon data-element="@cref"
                 points="@cone.X,@(cy - 2 * cs) @(cone.X - 1.5 * cs),@(cy + cs) @(cone.X + 1.5 * cs),@(cy + cs)"
                 fill="@cone.Color"
                 style="cursor:pointer;"
                 @onmousedown="(e) => HandleElementMouseDown(e, cref)"
                 @onmousedown:stopPropagation="true"
                 @onclick:stopPropagation="true"
                 @onclick="() => HandleElementClick(cref)"/>
    }

    <!-- Coaches -->
    @for (var ki = 0; ki < State.Diagram.Coaches.Count; ki++)
    {
        var coach = State.Diagram.Coaches[ki];
        var kref = $"coaches/{ki}";
        @if (State.SelectedElement == kref)
        {
            <circle cx="@coach.X" cy="@(coach.Y * _pitchHeight / 100)"
                    r="@(coach.Radius + 1.2)"
                    fill="none" stroke="white" stroke-width="0.4" stroke-dasharray="1,1"
                    pointer-events="none"/>
        }
        <g data-element="@kref"
           style="cursor:pointer;"
           @onmousedown="(e) => HandleElementMouseDown(e, kref)"
           @onmousedown:stopPropagation="true"
           @onclick:stopPropagation="true"
           @onclick="() => HandleElementClick(kref)">
            <circle cx="@coach.X" cy="@(coach.Y * _pitchHeight / 100)"
                    r="@coach.Radius" fill="#f0a500" stroke="white" stroke-width="0.4"/>
            @((MarkupString)$"<text x=\"{coach.X.ToString(System.Globalization.CultureInfo.InvariantCulture)}\" y=\"{(coach.Y * _pitchHeight / 100).ToString(System.Globalization.CultureInfo.InvariantCulture)}\" text-anchor=\"middle\" dominant-baseline=\"middle\" fill=\"white\" font-size=\"1.8\" font-weight=\"bold\" pointer-events=\"none\">{System.Net.WebUtility.HtmlEncode(coach.Label)}</text>")
        </g>
    }

    <!-- Players -->
    @for (var ti = 0; ti < State.Diagram.Teams.Count; ti++)
    {
        var team = State.Diagram.Teams[ti];
        for (var pi = 0; pi < team.Players.Count; pi++)
        {
            var player = team.Players[pi];
            var pref = $"teams/{ti}/players/{pi}";
            @if (State.SelectedElement == pref)
            {
                <circle cx="@player.X" cy="@(player.Y * _pitchHeight / 100)"
                        r="@(player.Radius + 1.2)"
                        fill="none" stroke="white" stroke-width="0.4" stroke-dasharray="1,1"
                        pointer-events="none"/>
            }
            <g data-element="@pref"
               style="cursor:pointer;"
               @onmousedown="(e) => HandleElementMouseDown(e, pref)"
               @onmousedown:stopPropagation="true"
               @onclick:stopPropagation="true"
               @onclick="() => HandleElementClick(pref)">
                <circle cx="@player.X" cy="@(player.Y * _pitchHeight / 100)"
                        r="@player.Radius" fill="@team.Color" stroke="white" stroke-width="0.4"/>
                @if (!string.IsNullOrEmpty(player.Label))
                {
                    @((MarkupString)$"<text x=\"{player.X.ToString(System.Globalization.CultureInfo.InvariantCulture)}\" y=\"{(player.Y * _pitchHeight / 100).ToString(System.Globalization.CultureInfo.InvariantCulture)}\" text-anchor=\"middle\" dominant-baseline=\"middle\" fill=\"white\" font-size=\"1.8\" font-weight=\"bold\" pointer-events=\"none\">{System.Net.WebUtility.HtmlEncode(player.Label)}</text>")
                }
            </g>
        }
    }

    <!-- Arrows -->
    @for (var ai = 0; ai < State.Diagram.Arrows.Count; ai++)
    {
        var arrow = State.Diagram.Arrows[ai];
        var aref = $"arrows/{ai}";
        var stroke = arrow.Color ?? ResolvedArrowColor(arrow.Style);
        var dasharray = arrow.Style == ArrowStyle.Pass ? "2,2" : "none";
        <path data-element="@aref"
              d="@BuildArrowPath(arrow)"
              stroke="@stroke"
              stroke-width="@(arrow.Style == ArrowStyle.Pass ? "0.4" : "0.5")"
              stroke-dasharray="@dasharray"
              fill="none"
              marker-end="url(#arr-@(_svgId)-@ai)"
              style="cursor:pointer;"
              @onmousedown="(e) => HandleElementMouseDown(e, aref)"
              @onmousedown:stopPropagation="true"
              @onclick:stopPropagation="true"
              @onclick="() => HandleElementClick(aref)"/>
        @if (State.SelectedElement == aref)
        {
            // Pre-capture handle refs — Blazor Razor cannot use string interpolation directly
            // inside event handler attributes without compilation errors.
            var tailRef  = $"{aref}/tail";
            var tipRef   = $"{aref}/tip";
            var curveRef = $"{aref}/curve";

            <!-- Dashed selection outline -->
            <path d="@BuildArrowPath(arrow)"
                  stroke="white" stroke-width="0.8" stroke-dasharray="1.5,1.5"
                  fill="none" opacity="0.4" pointer-events="none"/>

            <!-- Tail handle -->
            <circle data-element="@tailRef"
                    cx="@arrow.X1" cy="@(arrow.Y1 * _pitchHeight / 100)"
                    r="1.8" fill="white" stroke="rgba(0,0,0,0.6)" stroke-width="0.3"
                    style="cursor:move;"
                    @onmousedown="(e) => HandleElementMouseDown(e, tailRef)"
                    @onmousedown:stopPropagation="true"
                    @onclick="() => {}"
                    @onclick:stopPropagation="true"/>

            <!-- Tip handle -->
            <circle data-element="@tipRef"
                    cx="@arrow.X2" cy="@(arrow.Y2 * _pitchHeight / 100)"
                    r="1.8" fill="white" stroke="rgba(0,0,0,0.6)" stroke-width="0.3"
                    style="cursor:move;"
                    @onmousedown="(e) => HandleElementMouseDown(e, tipRef)"
                    @onmousedown:stopPropagation="true"
                    @onclick="() => {}"
                    @onclick:stopPropagation="true"/>

            <!-- Curve handle (yellow — visually distinct from tail/tip) -->
            <circle data-element="@curveRef"
                    cx="@arrow.Cx" cy="@(arrow.Cy * _pitchHeight / 100)"
                    r="1.4" fill="#ffeb3b" stroke="rgba(0,0,0,0.6)" stroke-width="0.3"
                    style="cursor:move;"
                    @onmousedown="(e) => HandleElementMouseDown(e, curveRef)"
                    @onmousedown:stopPropagation="true"
                    @onclick="() => {}"
                    @onclick:stopPropagation="true"/>
        }
    }

    <!-- Legend -->
    @if (State.Diagram.Legend != null)
    {
        var leg = State.Diagram.Legend;
        var ic3 = System.Globalization.CultureInfo.InvariantCulture;
        string LF(double v) => v.ToString("F2", ic3);

        var legendEntries = State.Diagram.Arrows
            .Where(a => a.SequenceNumber.HasValue)
            .Select(a => (Color: a.Color ?? ResolvedArrowColor(a.Style), Number: a.SequenceNumber!.Value))
            .Distinct()
            .OrderBy(e => e.Number)
            .ToList();

        const double legendWidth = 22.0;
        const double headerH = 5.0;
        const double rowH = 4.5;
        const double pad = 1.5;
        var contentH = _legendCollapsed ? 0.0 : legendEntries.Count * rowH;
        var legendH = headerH + contentH + pad;
        var lx = leg.X;
        var ly = leg.Y * _pitchHeight / 100;
        var legendRef = "legend";
        var isLegendSelected = State.SelectedElement == legendRef;

        @if (isLegendSelected)
        {
            <rect x="@LF(lx - 0.5)" y="@LF(ly - 0.5)"
                  width="@LF(legendWidth + 1)" height="@LF(legendH + 1)"
                  fill="none" stroke="white" stroke-width="0.4" stroke-dasharray="1,1"
                  pointer-events="none"/>
        }

        <rect data-element="@legendRef"
              x="@LF(lx)" y="@LF(ly)"
              width="@LF(legendWidth)" height="@LF(legendH)"
              rx="1.5" ry="1.5"
              fill="rgba(0,0,0,0.65)" stroke="rgba(255,255,255,0.3)" stroke-width="0.4"
              style="cursor:pointer;"
              @onmousedown="(e) => HandleElementMouseDown(e, legendRef)"
              @onmousedown:stopPropagation="true"
              @onclick:stopPropagation="true"
              @onclick="() => HandleElementClick(legendRef)"/>

        @((MarkupString)$"<text x=\"{LF(lx + pad)}\" y=\"{LF(ly + headerH / 2)}\" fill=\"white\" font-size=\"2.5\" font-weight=\"bold\" dominant-baseline=\"middle\" pointer-events=\"none\">Legend</text>")

        <g style="cursor:pointer;"
           @onclick="() => _legendCollapsed = !_legendCollapsed"
           @onclick:stopPropagation="true">
            @((MarkupString)$"<text x=\"{LF(lx + legendWidth - pad - 1.5)}\" y=\"{LF(ly + headerH / 2)}\" fill=\"white\" font-size=\"2.8\" dominant-baseline=\"middle\" text-anchor=\"middle\">{(_legendCollapsed ? "&#x25B6;" : "&#x25BC;")}</text>")
        </g>

        @if (!_legendCollapsed)
        {
            @for (var ri = 0; ri < legendEntries.Count; ri++)
            {
                var entry = legendEntries[ri];
                var ey = ly + headerH + ri * rowH + rowH / 2;
                <circle cx="@LF(lx + pad + 1.5)" cy="@LF(ey)"
                        r="1.2" fill="@entry.Color" pointer-events="none"/>
                @((MarkupString)$"<text x=\"{LF(lx + pad + 4.5)}\" y=\"{LF(ey)}\" fill=\"white\" font-size=\"2.5\" dominant-baseline=\"middle\" pointer-events=\"none\">{entry.Number}</text>")
            }
        }
    }

    <!-- Ghost cursor for active placement tools -->
    @if (_ghostX >= 0 && IsPlacementTool)
    {
        <circle cx="@_ghostX" cy="@_ghostY"
                r="2" fill="rgba(255,255,255,0.25)" stroke="rgba(255,255,255,0.5)"
                stroke-dasharray="1,1" stroke-width="0.4"
                pointer-events="none"/>
    }
</svg>

@code {
    [Parameter, EditorRequired] public DiagramEditorState State { get; set; } = null!;
    [Parameter] public EventCallback<(double X, double Y)> OnPlacePlayer { get; set; }
    [Parameter] public EventCallback<(double X, double Y)> OnPlaceCoach { get; set; }
    [Parameter] public EventCallback<(double X, double Y)> OnPlaceCone { get; set; }
    [Parameter] public EventCallback<(double X, double Y)> OnPlaceGoal { get; set; }
    [Parameter] public EventCallback<(double X, double Y)> OnArrowPoint { get; set; }
    [Parameter] public EventCallback<string> OnElementClick { get; set; }
    [Parameter] public EventCallback OnDeselect { get; set; }

    private readonly string _svgId = $"pitch-{Guid.NewGuid():N}";
    private double _ghostX = -1;
    private double _ghostY = -1;

    // True while a JS-driven drag is in progress (used to roll back undo on dispose).
    private bool _isDragging;
    private bool _legendCollapsed;

    // DotNetObjectReference passed to JS so it can invoke OnDragEnd.
    private DotNetObjectReference<DiagramCanvas>? _dotNetRef;

    // Cached SVG bounding rect for client→SVG coordinate conversion (placement clicks + ghost).
    private record SvgRect(double Left, double Top, double Width, double Height);
    private SvgRect? _svgRect;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _dotNetRef = DotNetObjectReference.Create(this);
        try
        {
            _svgRect = await JS.InvokeAsync<SvgRect>("diagramInterop.getSvgRect", _svgId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "getSvgRect failed");
        }
    }

    // Convert viewport client coordinates to SVG viewBox-percent coordinates.
    // Falls back to a 1:1 pass-through when the rect is unavailable (e.g. in unit tests).
    private (double x, double y) ToSvgCoords(double clientX, double clientY)
    {
        if (_svgRect is null or { Width: <= 0 })
            return (clientX, clientY);
        return (
            Math.Clamp((clientX - _svgRect.Left) / _svgRect.Width * 100, 0, 100),
            Math.Clamp((clientY - _svgRect.Top) / _svgRect.Height * 100, 0, 100)
        );
    }

    private double _pitchHeight => State.Diagram.PitchFormat switch
    {
        // Full field: height = WidthM / LengthM × 100
        PitchFormat.ElevenVElevenFull => 64.76, // 68/105 × 100
        PitchFormat.NineVNineFull => 62.5, // 50/80  × 100
        PitchFormat.SevenVSevenFull => 66.67, // 40/60  × 100
        // Half field (rotated, goal at bottom): same canvas size as full field
        PitchFormat.ElevenVElevenHalf => 64.76,
        PitchFormat.NineVNineHalf => 62.5,
        PitchFormat.SevenVSevenHalf => 66.67,
        PitchFormat.Custom when State.Diagram is { CustomHeight: { } h, CustomWidth: { } w }
            => h / w * 100.0,
        _ => 64.76
    };

    // Real-world pitch dimensions and marking positions per format.
    // LengthM = goal-to-goal distance (or goal-to-centre for half-field formats).
    // WidthM  = touchline-to-touchline.
    private record PitchDimensions(
        double LengthM,
        double WidthM,
        double PenAreaDepthM,
        double PenAreaHalfWidthM,
        double SixYardDepthM,
        double SixYardHalfWidthM,
        double PenSpotM,
        double CircleRadiusM,
        double GoalHalfWidthM);

    private PitchDimensions _dims => State.Diagram.PitchFormat switch
    {
        PitchFormat.ElevenVElevenFull or PitchFormat.ElevenVElevenHalf => new(105, 68, 16.5, 20.16, 5.5, 9.16, 11, 9.15, 3.66),
        PitchFormat.NineVNineFull or PitchFormat.NineVNineHalf => new(80, 50, 12, 14, 4, 6, 9, 9.15, 2.5),
        PitchFormat.SevenVSevenFull or PitchFormat.SevenVSevenHalf => new(60, 40, 10, 10, 3.5, 4, 7, 7.0, 2.0),
        _ => new(105, 68, 16.5, 20.16, 5.5, 9.16, 11, 9.15, 3.66)
    };

    private bool _isHalfField => State.Diagram.PitchFormat is
        PitchFormat.ElevenVElevenHalf or PitchFormat.NineVNineHalf or PitchFormat.SevenVSevenHalf;

    // Convert metres from left goal line → SVG x (field occupies x 2–98).
    private double Fx(double m) => 2 + (m / _dims.LengthM) * 96;

    // Convert metres from top touchline → SVG y (field occupies y Fy(0)–Fy(WidthM)).
    private double Fy(double m) => (2 + (m / _dims.WidthM) * 96) * _pitchHeight / 100.0;

    private string BuildPitchMarkings()
    {
        var d = _dims;
        var sb = new System.Text.StringBuilder();
        var ic = System.Globalization.CultureInfo.InvariantCulture;
        string F(double v) => v.ToString("F2", ic);

        double yT = Fy(0);
        double yB = Fy(d.WidthM);
        double yMid = Fy(d.WidthM / 2);

        const string thick = "stroke=\"rgba(255,255,255,0.6)\" stroke-width=\"0.5\" fill=\"none\"";
        const string thin = "stroke=\"rgba(255,255,255,0.4)\" stroke-width=\"0.3\" fill=\"none\"";
        const string faint = "stroke=\"rgba(255,255,255,0.35)\" stroke-width=\"0.3\" fill=\"none\"";

        if (_isHalfField)
        {
            // Half-field: rotated 90° — field width (W) is horizontal, half-length (HL) is
            // vertical. Goal is at the bottom; centre line is at the top.
            double pH = _pitchHeight;
            double W = d.WidthM;
            double HL = d.LengthM / 2.0;
            double xs = 96.0 / W; // SVG x units per metre across field
            double ys = (pH - 4.0) / HL; // SVG y units per metre of depth

            // FxH: metres from left touchline → SVG x
            double FxH(double m) => 2.0 + m * xs;

            // FyH: metres from goal line → SVG y  (0 = goal line = bottom, HL = centre = top)
            double FyH(double depth) => (pH - 2.0) - depth * ys;

            // Outer boundary
            sb.Append($"<rect x=\"2\" y=\"2\" width=\"96\" height=\"{F(pH - 4.0)}\" {thick}/>");

            // Penalty area
            double penL = FxH(W / 2.0 - d.PenAreaHalfWidthM);
            double penR = FxH(W / 2.0 + d.PenAreaHalfWidthM);
            double penTop = FyH(d.PenAreaDepthM);
            double penBot = FyH(0.0); // goal line = bottom edge
            sb.Append($"<rect x=\"{F(penL)}\" y=\"{F(penTop)}\" width=\"{F(penR - penL)}\" height=\"{F(penBot - penTop)}\" {thick}/>");

            // Six-yard box
            double sixL = FxH(W / 2.0 - d.SixYardHalfWidthM);
            double sixR = FxH(W / 2.0 + d.SixYardHalfWidthM);
            double sixTop = FyH(d.SixYardDepthM);
            sb.Append($"<rect x=\"{F(sixL)}\" y=\"{F(sixTop)}\" width=\"{F(sixR - sixL)}\" height=\"{F(penBot - sixTop)}\" {thick}/>");

            // Penalty spot
            double spotX = 50.0; // FxH(W/2) = 2 + 48 = 50
            double spotY = FyH(d.PenSpotM);
            sb.Append($"<circle cx=\"{F(spotX)}\" cy=\"{F(spotY)}\" r=\"0.4\" fill=\"rgba(255,255,255,0.5)\" stroke=\"none\"/>");

            // Penalty arc (elliptical — x and y scales differ in this orientation)
            double arcRx = d.CircleRadiusM * xs;
            double arcRy = d.CircleRadiusM * ys;
            double ellDy = penTop - spotY; // negative: penTop is above spotY
            double ellDyRy = ellDy / arcRy;
            if (ellDyRy * ellDyRy < 1.0)
            {
                double arcDx = arcRx * Math.Sqrt(1.0 - ellDyRy * ellDyRy);
                // sweep=1 (clockwise in SVG Y-down) → arc bulges upward, outside the penalty area.
                sb.Append($"<path d=\"M {F(spotX - arcDx)} {F(penTop)} A {F(arcRx)} {F(arcRy)} 0 0 1 {F(spotX + arcDx)} {F(penTop)}\" {faint}/>");
            }

            // Goal (extends below goal line — visible via overflow:visible)
            double goalL = FxH(W / 2.0 - d.GoalHalfWidthM);
            double goalR = FxH(W / 2.0 + d.GoalHalfWidthM);
            sb.Append($"<rect x=\"{F(goalL)}\" y=\"{F(penBot)}\" width=\"{F(goalR - goalL)}\" height=\"2.5\" stroke=\"rgba(255,255,255,0.85)\" stroke-width=\"0.6\" fill=\"none\"/>");

            // Corner arcs at bottom corners (goal line × touchlines)
            double rCor = Math.Max(xs, 0.5);
            // Bottom-left: (2, pH-2)
            sb.Append($"<path d=\"M 2 {F(penBot - rCor)} A {F(rCor)} {F(rCor)} 0 0 1 {F(2 + rCor)} {F(penBot)}\" {faint}/>");
            // Bottom-right: (98, pH-2)
            sb.Append($"<path d=\"M 98 {F(penBot - rCor)} A {F(rCor)} {F(rCor)} 0 0 0 {F(98 - rCor)} {F(penBot)}\" {faint}/>");
        }
        else
        {
            // Full-field boundary
            sb.Append($"<rect x=\"2\" y=\"{F(yT)}\" width=\"96\" height=\"{F(yB - yT)}\" {thick}/>");

            // Halfway line
            sb.Append($"<line x1=\"50\" y1=\"{F(yT)}\" x2=\"50\" y2=\"{F(yB)}\" {thin}/>");

            // Centre circle
            double rC = (d.CircleRadiusM / d.LengthM) * 96;
            sb.Append($"<circle cx=\"50\" cy=\"{F(yMid)}\" r=\"{F(rC)}\" {thin}/>");

            // Centre spot
            sb.Append($"<circle cx=\"50\" cy=\"{F(yMid)}\" r=\"0.4\" fill=\"rgba(255,255,255,0.5)\" stroke=\"none\"/>");

            void AddEnd(bool left)
            {
                double xPen = left ? Fx(d.PenAreaDepthM) : Fx(d.LengthM - d.PenAreaDepthM);
                double xSix = left ? Fx(d.SixYardDepthM) : Fx(d.LengthM - d.SixYardDepthM);
                double xSpot = left ? Fx(d.PenSpotM) : Fx(d.LengthM - d.PenSpotM);
                double xGoal = left ? 2.0 : 98.0;
                double xGolOuter = left ? xGoal - 2.5 : xGoal + 2.5;

                double yPenT = Fy(d.WidthM / 2 - d.PenAreaHalfWidthM);
                double yPenB = Fy(d.WidthM / 2 + d.PenAreaHalfWidthM);
                double ySixT = Fy(d.WidthM / 2 - d.SixYardHalfWidthM);
                double ySixB = Fy(d.WidthM / 2 + d.SixYardHalfWidthM);
                double yGolT = Fy(d.WidthM / 2 - d.GoalHalfWidthM);
                double yGolB = Fy(d.WidthM / 2 + d.GoalHalfWidthM);

                // Penalty area
                double penX = Math.Min(xGoal, xPen);
                double penW = Math.Abs(xPen - xGoal);
                sb.Append($"<rect x=\"{F(penX)}\" y=\"{F(yPenT)}\" width=\"{F(penW)}\" height=\"{F(yPenB - yPenT)}\" {thick}/>");

                // Six-yard box
                double sixX = Math.Min(xGoal, xSix);
                double sixW = Math.Abs(xSix - xGoal);
                sb.Append($"<rect x=\"{F(sixX)}\" y=\"{F(ySixT)}\" width=\"{F(sixW)}\" height=\"{F(ySixB - ySixT)}\" {thick}/>");

                // Penalty spot
                sb.Append($"<circle cx=\"{F(xSpot)}\" cy=\"{F(yMid)}\" r=\"0.4\" fill=\"rgba(255,255,255,0.5)\" stroke=\"none\"/>");

                // Penalty arc (the arc of the 9.15 m circle that lies outside the penalty area)
                double arcR = (d.CircleRadiusM / d.LengthM) * 96;
                double arcDx = Math.Abs(xPen - xSpot);
                if (arcR > arcDx)
                {
                    double arcDy = Math.Sqrt(arcR * arcR - arcDx * arcDx);
                    int sweep = left ? 1 : 0;
                    sb.Append($"<path d=\"M {F(xPen)} {F(yMid - arcDy)} A {F(arcR)} {F(arcR)} 0 0 {sweep} {F(xPen)} {F(yMid + arcDy)}\" {faint}/>");
                }

                // Goal (extends 2.5 units outside the pitch boundary)
                var gx = left ? xGolOuter : xGoal;
                var gw = 2.5;
                sb.Append($"<rect x=\"{F(gx)}\" y=\"{F(yGolT)}\" width=\"{F(gw)}\" height=\"{F(yGolB - yGolT)}\" stroke=\"rgba(255,255,255,0.85)\" stroke-width=\"0.6\" fill=\"none\"/>");

                // Corner arcs
                double rCor = Math.Max((1.0 / d.LengthM) * 96, 0.4);
                if (left)
                {
                    sb.Append($"<path d=\"M {F(2 + rCor)} {F(yT)} A {F(rCor)} {F(rCor)} 0 0 0 2 {F(yT + rCor)}\" {faint}/>");
                    sb.Append($"<path d=\"M 2 {F(yB - rCor)} A {F(rCor)} {F(rCor)} 0 0 1 {F(2 + rCor)} {F(yB)}\" {faint}/>");
                }
                else
                {
                    sb.Append($"<path d=\"M {F(98 - rCor)} {F(yT)} A {F(rCor)} {F(rCor)} 0 0 1 98 {F(yT + rCor)}\" {faint}/>");
                    sb.Append($"<path d=\"M 98 {F(yB - rCor)} A {F(rCor)} {F(rCor)} 0 0 0 {F(98 - rCor)} {F(yB)}\" {faint}/>");
                }
            }

            AddEnd(left: true);
            AddEnd(left: false);
        }

        return sb.ToString();
    }

    private bool IsPlacementTool => State.ActiveTool is
        "player" or "coach" or "cone" or "goal" or
        "arrow-run" or "arrow-pass" or "arrow-dribble";

    private string _cursor => State.ActiveTool switch
    {
        "move" => "move",
        "delete" => "crosshair",
        _ when IsPlacementTool => "crosshair",
        _ => "default"
    };

    private static string ResolvedArrowColor(ArrowStyle style) => style switch
    {
        ArrowStyle.Pass    => "#90caf9",
        ArrowStyle.Dribble => "#ffcc80",
        _                  => "white"
    };

    // Called when the user presses the mouse button on a draggable element.
    // Drag is available by default when no tool is active.
    // Pushes undo state and delegates drag tracking to JS (document-level listeners).
    private async Task HandleElementMouseDown(MouseEventArgs e, string elementRef)
    {
        if (State.ActiveTool != null) return;
        State.BeginDrag();
        _isDragging = true;
        try
        {
            await JS.InvokeVoidAsync("diagramInterop.startDrag",
                _svgId, elementRef, e.ClientX, e.ClientY, _dotNetRef);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "startDrag failed for {ElementRef}", elementRef);
            _isDragging = false;
            State.Undo();
        }
    }

    // Called by JS on mouseup with the model-coordinate delta (dx, dy).
    // Applies the delta to the element so arrows (and all other elements) move as a whole.
    [JSInvokable]
    public void OnDragEnd(string elementRef, double dx, double dy)
    {
        if (!_isDragging) return;
        _isDragging = false;
        State.MoveByDelta(elementRef, dx, dy);
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleSvgClick(MouseEventArgs e)
    {
        var (x, y) = ToSvgCoords(e.ClientX, e.ClientY);

        switch (State.ActiveTool)
        {
            case "player": await OnPlacePlayer.InvokeAsync((x, y)); break;
            case "coach": await OnPlaceCoach.InvokeAsync((x, y)); break;
            case "cone": await OnPlaceCone.InvokeAsync((x, y)); break;
            case "goal": await OnPlaceGoal.InvokeAsync((x, y)); break;
            case "arrow-run":
            case "arrow-pass":
            case "arrow-dribble": await OnArrowPoint.InvokeAsync((x, y)); break;
            case null: await OnDeselect.InvokeAsync(); break;
        }
    }

    private Task HandleElementClick(string elementRef)
        => OnElementClick.InvokeAsync(elementRef);

    // Updates the ghost cursor position for placement tools.
    // Drag movement is handled entirely by JS document-level listeners.
    private void HandleSvgMouseMove(MouseEventArgs e)
    {
        if (!IsPlacementTool) return;
        var (gx, gy) = ToSvgCoords(e.ClientX, e.ClientY);
        _ghostX = gx;
        _ghostY = gy * _pitchHeight / 100.0;
    }

    private string BuildArrowPath(ArrowElement arrow)
    {
        var x1 = arrow.X1;
        var y1 = arrow.Y1 * _pitchHeight / 100;
        var x2 = arrow.X2;
        var y2 = arrow.Y2 * _pitchHeight / 100;
        var cx = arrow.Cx;
        var cy = arrow.Cy * _pitchHeight / 100;

        if (arrow.Style == ArrowStyle.Dribble)
        {
            const int waves = 4;
            var ic2 = System.Globalization.CultureInfo.InvariantCulture;
            string Fmt(double v) => v.ToString("F2", ic2);

            // Bezier point at parameter t: B(t) = (1-t)²·P0 + 2t(1-t)·Pc + t²·P1
            double Bx(double t) => (1-t)*(1-t)*x1 + 2*t*(1-t)*cx + t*t*x2;
            double By(double t) => (1-t)*(1-t)*y1 + 2*t*(1-t)*cy + t*t*y2;
            // Bezier tangent (un-normalized): B'(t) = 2(1-t)(Pc-P0) + 2t(P1-Pc)
            double Tx(double t) => 2*(1-t)*(cx-x1) + 2*t*(x2-cx);
            double Ty(double t) => 2*(1-t)*(cy-y1) + 2*t*(y2-cy);

            var sb = new System.Text.StringBuilder();
            sb.Append($"M {Fmt(Bx(0))} {Fmt(By(0))}");

            for (var i = 0; i < waves; i++)
            {
                double tm = (i + 0.5) / waves; // midpoint of this wave segment
                double te = (i + 1.0) / waves; // end of this wave segment

                double tangX = Tx(tm);
                double tangY = Ty(tm);
                double tlen = Math.Sqrt(tangX * tangX + tangY * tangY);

                // Bezier midpoint + perpendicular offset to create the wave bulge
                double pmx = Bx(tm);
                double pmy = By(tm);
                double amp = (i % 2 == 0 ? 1.5 : -1.5);
                double cpx = pmx + (tlen > 0 ? -tangY / tlen * amp : 0);
                double cpy = pmy + (tlen > 0 ?  tangX / tlen * amp : 0);

                sb.Append($" Q {Fmt(cpx)} {Fmt(cpy)} {Fmt(Bx(te))} {Fmt(By(te))}");
            }
            return sb.ToString();
        }

        return $"M {x1.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)} {y1.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)} Q {cx.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)} {cy.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)} {x2.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)} {y2.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    public async ValueTask DisposeAsync()
    {
        // Roll back the speculative undo entry if disposed mid-drag.
        if (_isDragging)
            State.Undo();
        try { await JS.InvokeVoidAsync("diagramInterop.cancelDrag"); }
        catch { /* component may be gone; ignore */ }
        _dotNetRef?.Dispose();
    }

}
